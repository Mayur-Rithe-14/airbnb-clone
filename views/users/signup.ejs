<div class="row justify-content-center auth-page">
  <div class="col-12 col-md-8 col-lg-6">
    <h2 class="text-center mb-4">Signup On Wanderlust</h2>

    <form
      action="/signup"
      method="POST"
      class="needs-validation auth-form"
      novalidate
    >
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input
          type="text"
          name="username"
          id="username"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks Good!</div>
      </div>

      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          class="form-control"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks Good!</div>
      </div>

      <button class="btn btn-success w-100">Sign Up</button>
    </form>
  </div>
</div>
